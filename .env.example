# ---- LLM ----
# Provider: anthropic | openai | gemini | groq | deepseek
COPILOT_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
# All five providers' SDKs ship in the base install — just set COPILOT_PROVIDER + the key.
# Optional model overrides (blank = provider defaults:
#   anthropic -> claude-opus-4-8 / claude-haiku-4-5
#   openai    -> gpt-4o / gpt-4o-mini
#   gemini    -> gemini-1.5-pro / gemini-1.5-flash
#   groq      -> llama-3.3-70b-versatile / llama-3.1-8b-instant
#   deepseek  -> deepseek-chat)
COPILOT_MODEL=
COPILOT_FAST_MODEL=

# ---- MCP servers ----
# Local repository the filesystem MCP server is allowed to read.
TARGET_REPO_PATH=./sample_repo
# Path the custom logs/metrics MCP server reads demo data from.
LOGS_DATA_PATH=./app/mcp/servers/logs_metrics/sample_data

# GitHub MCP (optional — leave blank to run in demo/offline mode)
GITHUB_TOKEN=
# Required only when GITHUB_TOKEN is set: which repo the real GitHub API targets.
GITHUB_REPO=

# Datadog observability MCP (optional — blank = offline demo fixtures).
# With both keys set, the connector queries the real Datadog API.
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com   # e.g. datadoghq.eu, us3.datadoghq.com

# PagerDuty alerting MCP (optional — blank = offline incident fixtures).
PAGERDUTY_API_TOKEN=
# Email identifying the actor for PagerDuty write actions (note/ack/resolve).
PAGERDUTY_FROM_EMAIL=

# Kubernetes MCP (optional — blank = offline pod/event fixtures). Set a kubeconfig
# path to query a real cluster (needs the `kubernetes` client: uv pip install kubernetes).
KUBE_CONFIG_PATH=
KUBE_NAMESPACE=default

# Sentry MCP (optional — blank = offline issue/event fixtures). Set a token + scope
# to query the real Sentry API.
SENTRY_API_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Incident-memory corpus for "have we seen this before?" search. Blank = the
# bundled demo corpus; point at your own JSON of prior RCAs/runbooks to search them.
INCIDENT_CORPUS_PATH=

# Distributed-traces MCP (optional — blank = offline span fixtures). Set a
# Jaeger-compatible query URL (e.g. http://jaeger:16686) to query real traces.
TRACES_API_URL=

# Deploys / change-events MCP (optional — blank = offline deploy fixtures). Set a
# deploy-tracker URL (Spinnaker/ArgoCD/CD webhook store) to query real deploys.
DEPLOYS_API_URL=
DEPLOYS_API_TOKEN=

# ---- Triggers / delivery: PagerDuty webhook -> investigate -> Slack approval ----
# Secret that signs the inbound PagerDuty v3 webhook (PagerDuty → Webhooks).
PAGERDUTY_WEBHOOK_SECRET=
# Slack app: posts investigations + Approve/Reject buttons, verifies callbacks.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL=

# ---- API ----
# Deployment mode: development | production. In production the server REFUSES to
# start unless COPILOT_API_TOKEN is set (no unauthenticated public API).
COPILOT_ENV=development
# Extra browser origins allowed by CORS (comma-separated). The Vite dev server
# (localhost:5173) is always allowed; set your deployed frontend origin here.
# (Not needed when the SPA is served same-origin from this backend.)
CORS_ORIGINS=
# Shared bearer token guarding every endpoint (except /healthz, /readyz). Empty =
# open (local dev). Set it in production; the frontend sends it via VITE_API_TOKEN.
COPILOT_API_TOKEN=
# Restrict /sources/* to this directory tree so the agent can't be aimed at
# arbitrary host paths. Empty = the project root (keeps the bundled demo working).
COPILOT_SOURCES_ROOT=

# ---- Production safety limits ----
# Per-client (IP) POST cap per minute; 0 disables rate limiting.
COPILOT_RATE_LIMIT_PER_MIN=120
# Max request body size in bytes.
COPILOT_MAX_BODY_BYTES=1000000
# Max characters per chat message.
COPILOT_MAX_MESSAGE_CHARS=16000
# Max concurrent in-memory sessions (LRU-idle evicted past this); 0 = unlimited.
# Each live session holds one stdio subprocess per MCP server (7), so keep modest.
COPILOT_MAX_SESSIONS=50
# Optional durable sinks (JSONL). Blank = in-memory only (audit) / ./feedback.jsonl.
COPILOT_AUDIT_LOG=
COPILOT_FEEDBACK_LOG=feedback.jsonl
# Deterministic record/replay of LLM calls for offline golden evals (app/replay.py).
# off (default) | record (needs a key) | replay (no key). See evals/run_golden.py.
COPILOT_REPLAY_MODE=off
COPILOT_CASSETTE_PATH=evals/cassettes/golden.json

# ---- Observability (optional) ----
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=devops-copilot
# Sentry error tracking (optional; needs `pip install sentry-sdk`). Empty = off.
SENTRY_DSN=
# Datadog APM self-instrumentation (optional; needs the `apm` extra + a DD agent).
# Traces the copilot itself; honors DD_SERVICE / DD_ENV / DD_AGENT_HOST.
DD_TRACE_ENABLED=false
# Datadog LLM Observability (optional; needs the `apm` extra). Traces the agent's
# LLM calls (prompts, tokens, tool/agent spans). With DD_API_KEY set and no agent
# it sends agentless. Note: these must be in the process ENV (export them or use
# ddtrace-run) — ddtrace reads os.environ, not the .env-loaded Settings.
DD_LLMOBS_ENABLED=
DD_LLMOBS_ML_APP=devops-copilot
# DD_SITE for LLMObs (e.g. us5.datadoghq.com); DD_API_KEY is shared with the connector above.
# Log format: json | text (defaults to json in production, text in development).
LOG_FORMAT=

# ---- Multi-tenancy (commercial; opt-in) ----
# false (default) = single-tenant offline demo, unchanged. true = require per-tenant
# API keys (dcp_…), resolve per-tenant config/integrations/quotas, enforce RBAC.
COPILOT_MULTI_TENANT=false
# Tenant store: SQLite path (default) or a postgres://… URL in production.
COPILOT_TENANT_DB=./copilot_tenants.sqlite
# Stripe metered billing (optional; test key sk_test_…). Empty = local-ledger-only.
STRIPE_API_KEY=
STRIPE_METER_EVENT=investigation
# Supabase / OIDC SSO login (optional). With the public JWKS URL set, a Supabase
# JWT (Bearer) authenticates to the multi-tenant API, mapped to the user's org/role.
# Verification uses ONLY the public JWKS — no Supabase secret/publishable key needed.
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUD=authenticated
# Self-serve onboarding: when true (and multi-tenant is on), POST /signup lets a
# new user create an org + owner API key with no prior credential (always on the
# free plan). Set false to require admin/CLI provisioning instead.
COPILOT_SIGNUP_ENABLED=true

# ---- Agent behavior ----
# Max agent (LLM) calls per investigation turn — bounds the agent<->tools loop.
COPILOT_MAX_ITERATIONS=8
# Token budget per investigation (sum of all LLM calls). When crossed, the agent
# is forced to conclude on its next step — a hard cost kill-switch. 0 = unlimited.
COPILOT_MAX_TOKENS_PER_RUN=0
# FLEET-WIDE token ceiling over a rolling window across ALL investigations — the
# global backstop above per-run + per-tenant budgets. New investigations are refused
# (429) once crossed. 0 = unlimited. Shared across replicas when COPILOT_REDIS_URL set.
COPILOT_GLOBAL_TOKEN_CAP=0
COPILOT_GLOBAL_SPEND_WINDOW_S=86400   # rolling budget window (default 24h)
COPILOT_GLOBAL_SPEND_ALERT=0.8        # warn in logs past this fraction of the cap
# Prompt caching (Anthropic only): cache the stable system prompt + bound tool
# schemas so the agent's many loop iterations re-read them at ~0.1x input cost.
# No-op on other providers. true (default) | false.
COPILOT_PROMPT_CACHE=true
# Fix verification: after the RCA report, a verify node checks whether the proposed
# fix addresses the root cause and emits resolution criteria. true (default) | false.
COPILOT_VERIFY_FIX=true
# How many times an unverified fix may be bounced back to the agent to revise.
# Bounds the revision loop; 0 = annotate only, never loop. Default 1.
COPILOT_VERIFY_MAX_ATTEMPTS=1
# Sandbox counterfactual: when the agent attaches a unified-diff `patch` to its PR,
# apply it to a throwaway copy of the target repo and run a reproducer to PROVE the
# fix (FAIL→PASS). Executes the model's patch (contained: temp copy, timeout), so
# OFF by default. true | false (default).
COPILOT_SANDBOX_VERIFY=false
# Reproducer command run in the temp repo copy before/after the patch (operator-set,
# never model-supplied). Defaults to the bundled sample_repo node reproducer.
COPILOT_SANDBOX_CMD=node checkout.test.js
# Wall-clock timeout (seconds) per sandbox subprocess run.
COPILOT_SANDBOX_TIMEOUT_S=30
# Confidence gate: refuse to AUTO-approve a consequential write that rests on thin
# evidence (a human can still approve it explicitly). Protects programmatic
# approvers — evals/bots/auto-remediation — from rubber-stamping. true (default).
COPILOT_CONFIDENCE_GATE=true
# Continual learning: after a confidently-resolved investigation, append a runbook
# record to the learned incident corpus so future runs warm-start from it. Only
# non-abstained runs with a root cause are recorded. true (default) | false.
COPILOT_LEARN_INCIDENTS=true
# Where learned incidents accumulate (JSON). Empty = <project root>/learned_incidents.json.
# Kept separate from the bundled demo corpus so the shipped fixture is never mutated.
COPILOT_LEARNED_CORPUS=
# Adversarial RCA critique: a Prosecutor tries to refute the root cause and a
# Defender rebuts from observed evidence; a serious unrebutted objection abstains or
# downgrades the RCA. Two extra fast-model calls per run. true (default) | false.
COPILOT_ADVERSARIAL_CRITIQUE=true
# Model routing: triage clearly-informational requests onto the cheap fast model in
# the agent loop, reserving the main reasoning model for real incidents. true (default).
COPILOT_MODEL_ROUTING=true
# Proactive SLO poller: periodically evaluate error-budget burn and auto-open an
# investigation when page-worthy — before a human is paged. Spends tokens
# autonomously, so OFF by default. true | false (default).
COPILOT_SLO_POLLER=false
COPILOT_SLO_POLL_INTERVAL_S=300    # sweep cadence (seconds)
COPILOT_SLO_COOLDOWN_S=3600        # per-service re-open cooldown (seconds)
# Parallel multi-hypothesis probe: when the RCA has 2+ competing hypotheses, score
# each concurrently against the evidence and re-rank. true (default) | false.
COPILOT_PARALLEL_HYPOTHESES=true
# Resilience: bounded retries with exponential backoff + a circuit breaker around
# each LLM call (survives transient 429/5xx/timeouts; stops hammering a dead provider).
# 1 disables retries. Default 3.
COPILOT_LLM_RETRIES=3
# Optional cross-provider failover when the primary stays unavailable — one of
# anthropic|openai|gemini|groq|deepseek (needs that provider's key). Empty = off.
COPILOT_FALLBACK_PROVIDER=
# Progressive-autonomy remediation (POST /remediate): apply a REVERSIBLE fix, watch
# the signal, auto-revert on regression. Mutates real infra — DOUBLY gated: OFF by
# default, and dry-run even when enabled. Set BOTH to let it act. High-confidence,
# reversible actions (rollback/restart) only.
COPILOT_AUTONOMY=false
COPILOT_AUTONOMY_DRYRUN=true       # even when enabled, only simulate unless false
COPILOT_AUTONOMY_WATCH_S=60        # watch the signal this long before judging recovery
# Redis URL for the SHARED cross-replica rate limiter (and, later, the durable job
# queue). Empty = per-process in-memory limiter (single-instance). e.g. redis://redis:6379/0
COPILOT_REDIS_URL=
# Secrets provider for in-process secret resolution: env (default) | aws | vault.
# aws = AWS Secrets Manager (boto3); vault = HashiCorp Vault KV v2 (hvac). Non-env
# providers fall back to the environment. (K8s users can instead use External Secrets.)
COPILOT_SECRETS_PROVIDER=env
COPILOT_SECRETS_PREFIX=
# SQLite path (default) OR a postgres://... URL for multi-instance state
# (needs the `postgres` extra: uv pip install -e ".[postgres]").
COPILOT_CHECKPOINT_DB=./copilot_checkpoints.sqlite
# Fernet key for the per-tenant secret vault (needs the `secrets` extra). Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
COPILOT_SECRET_KEY=

# OpenTelemetry: set to your OTLP collector endpoint to enable distributed tracing
# (spans per investigation + MCP tool call). Empty = tracing off (no-op).
OTEL_EXPORTER_OTLP_ENDPOINT=

# SCIM 2.0 provisioning (enterprise SSO): bearer token the IdP presents + target org.
# Empty = SCIM disabled (403). Auth itself is OIDC/JWT via SUPABASE_JWKS_URL.
COPILOT_SCIM_TOKEN=
COPILOT_SCIM_ORG=
COPILOT_SCIM_DEFAULT_ROLE=responder

# Stripe webhook signing secret — verifies inbound subscription events at
# /webhooks/stripe (event -> plan). Empty = endpoint rejects (fails closed).
STRIPE_WEBHOOK_SECRET=
