# ---- LLM ----
# Provider: anthropic | openai | gemini | groq | deepseek
COPILOT_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
# All five providers' SDKs ship in the base install — just set COPILOT_PROVIDER + the key.
# Optional model overrides (blank = provider defaults:
#   anthropic -> claude-opus-4-8 / claude-haiku-4-5
#   openai    -> gpt-4o / gpt-4o-mini
#   gemini    -> gemini-1.5-pro / gemini-1.5-flash
#   groq      -> llama-3.3-70b-versatile / llama-3.1-8b-instant
#   deepseek  -> deepseek-chat)
COPILOT_MODEL=
COPILOT_FAST_MODEL=

# ---- MCP servers ----
# Local repository the filesystem MCP server is allowed to read.
TARGET_REPO_PATH=./sample_repo
# Path the custom logs/metrics MCP server reads demo data from.
LOGS_DATA_PATH=./app/mcp/servers/logs_metrics/sample_data

# GitHub MCP (optional — leave blank to run in demo/offline mode)
GITHUB_TOKEN=
# Required only when GITHUB_TOKEN is set: which repo the real GitHub API targets.
GITHUB_REPO=

# Datadog observability MCP (optional — blank = offline demo fixtures).
# With both keys set, the connector queries the real Datadog API.
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com   # e.g. datadoghq.eu, us3.datadoghq.com

# PagerDuty alerting MCP (optional — blank = offline incident fixtures).
PAGERDUTY_API_TOKEN=
# Email identifying the actor for PagerDuty write actions (note/ack/resolve).
PAGERDUTY_FROM_EMAIL=

# Kubernetes MCP (optional — blank = offline pod/event fixtures). Set a kubeconfig
# path to query a real cluster (needs the `kubernetes` client: uv pip install kubernetes).
KUBE_CONFIG_PATH=
KUBE_NAMESPACE=default

# Sentry MCP (optional — blank = offline issue/event fixtures). Set a token + scope
# to query the real Sentry API.
SENTRY_API_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Incident-memory corpus for "have we seen this before?" search. Blank = the
# bundled demo corpus; point at your own JSON of prior RCAs/runbooks to search them.
INCIDENT_CORPUS_PATH=

# Distributed-traces MCP (optional — blank = offline span fixtures). Set a
# Jaeger-compatible query URL (e.g. http://jaeger:16686) to query real traces.
TRACES_API_URL=

# Deploys / change-events MCP (optional — blank = offline deploy fixtures). Set a
# deploy-tracker URL (Spinnaker/ArgoCD/CD webhook store) to query real deploys.
DEPLOYS_API_URL=
DEPLOYS_API_TOKEN=

# ---- Triggers / delivery: PagerDuty webhook -> investigate -> Slack approval ----
# Secret that signs the inbound PagerDuty v3 webhook (PagerDuty → Webhooks).
PAGERDUTY_WEBHOOK_SECRET=
# Slack app: posts investigations + Approve/Reject buttons, verifies callbacks.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL=

# ---- API ----
# Deployment mode: development | production. In production the server REFUSES to
# start unless COPILOT_API_TOKEN is set (no unauthenticated public API).
COPILOT_ENV=development
# Extra browser origins allowed by CORS (comma-separated). The Vite dev server
# (localhost:5173) is always allowed; set your deployed frontend origin here.
# (Not needed when the SPA is served same-origin from this backend.)
CORS_ORIGINS=
# Shared bearer token guarding every endpoint (except /healthz, /readyz). Empty =
# open (local dev). Set it in production; the frontend sends it via VITE_API_TOKEN.
COPILOT_API_TOKEN=
# Restrict /sources/* to this directory tree so the agent can't be aimed at
# arbitrary host paths. Empty = the project root (keeps the bundled demo working).
COPILOT_SOURCES_ROOT=

# ---- Production safety limits ----
# Per-client (IP) POST cap per minute; 0 disables rate limiting.
COPILOT_RATE_LIMIT_PER_MIN=120
# Max request body size in bytes.
COPILOT_MAX_BODY_BYTES=1000000
# Max characters per chat message.
COPILOT_MAX_MESSAGE_CHARS=16000
# Max concurrent in-memory sessions (LRU-idle evicted past this); 0 = unlimited.
# Each live session holds one stdio subprocess per MCP server (7), so keep modest.
COPILOT_MAX_SESSIONS=50
# Optional durable sinks (JSONL). Blank = in-memory only (audit) / ./feedback.jsonl.
COPILOT_AUDIT_LOG=
COPILOT_FEEDBACK_LOG=feedback.jsonl
# Deterministic record/replay of LLM calls for offline golden evals (app/replay.py).
# off (default) | record (needs a key) | replay (no key). See evals/run_golden.py.
COPILOT_REPLAY_MODE=off
COPILOT_CASSETTE_PATH=evals/cassettes/golden.json

# ---- Observability (optional) ----
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=devops-copilot
# Sentry error tracking (optional; needs `pip install sentry-sdk`). Empty = off.
SENTRY_DSN=
# Datadog APM self-instrumentation (optional; needs the `apm` extra + a DD agent).
# Traces the copilot itself; honors DD_SERVICE / DD_ENV / DD_AGENT_HOST.
DD_TRACE_ENABLED=false
# Log format: json | text (defaults to json in production, text in development).
LOG_FORMAT=

# ---- Multi-tenancy (commercial; opt-in) ----
# false (default) = single-tenant offline demo, unchanged. true = require per-tenant
# API keys (dcp_…), resolve per-tenant config/integrations/quotas, enforce RBAC.
COPILOT_MULTI_TENANT=false
# Tenant store: SQLite path (default) or a postgres://… URL in production.
COPILOT_TENANT_DB=./copilot_tenants.sqlite

# ---- Agent behavior ----
# Max agent (LLM) calls per investigation turn — bounds the agent<->tools loop.
COPILOT_MAX_ITERATIONS=8
# Token budget per investigation (sum of all LLM calls). When crossed, the agent
# is forced to conclude on its next step — a hard cost kill-switch. 0 = unlimited.
COPILOT_MAX_TOKENS_PER_RUN=0
# SQLite path (default) OR a postgres://... URL for multi-instance state
# (needs the `postgres` extra: uv pip install -e ".[postgres]").
COPILOT_CHECKPOINT_DB=./copilot_checkpoints.sqlite
# Fernet key for the per-tenant secret vault (needs the `secrets` extra). Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
COPILOT_SECRET_KEY=
