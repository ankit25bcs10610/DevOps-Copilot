# ---- LLM ----
# Provider: anthropic | openai | gemini | groq | deepseek
COPILOT_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
# All five providers' SDKs ship in the base install — just set COPILOT_PROVIDER + the key.
# Optional model overrides (blank = provider defaults:
#   anthropic -> claude-opus-4-8 / claude-haiku-4-5
#   openai    -> gpt-4o / gpt-4o-mini
#   gemini    -> gemini-1.5-pro / gemini-1.5-flash
#   groq      -> llama-3.3-70b-versatile / llama-3.1-8b-instant
#   deepseek  -> deepseek-chat)
COPILOT_MODEL=
COPILOT_FAST_MODEL=

# ---- MCP servers ----
# Local repository the filesystem MCP server is allowed to read.
TARGET_REPO_PATH=./sample_repo
# Path the custom logs/metrics MCP server reads demo data from.
LOGS_DATA_PATH=./app/mcp/servers/logs_metrics/sample_data

# GitHub MCP (optional — leave blank to run in demo/offline mode)
GITHUB_TOKEN=
# Required only when GITHUB_TOKEN is set: which repo the real GitHub API targets.
GITHUB_REPO=

# ---- API ----
# Deployment mode: development | production. In production the server REFUSES to
# start unless COPILOT_API_TOKEN is set (no unauthenticated public API).
COPILOT_ENV=development
# Extra browser origins allowed by CORS (comma-separated). The Vite dev server
# (localhost:5173) is always allowed; set your deployed frontend origin here.
# (Not needed when the SPA is served same-origin from this backend.)
CORS_ORIGINS=
# Shared bearer token guarding every endpoint (except /healthz, /readyz). Empty =
# open (local dev). Set it in production; the frontend sends it via VITE_API_TOKEN.
COPILOT_API_TOKEN=
# Restrict /sources/* to this directory tree so the agent can't be aimed at
# arbitrary host paths. Empty = the project root (keeps the bundled demo working).
COPILOT_SOURCES_ROOT=

# ---- Production safety limits ----
# Per-client (IP) POST cap per minute; 0 disables rate limiting.
COPILOT_RATE_LIMIT_PER_MIN=120
# Max request body size in bytes.
COPILOT_MAX_BODY_BYTES=1000000
# Max characters per chat message.
COPILOT_MAX_MESSAGE_CHARS=16000
# Max concurrent in-memory sessions (LRU-idle evicted past this); 0 = unlimited.
# Each live session holds one stdio subprocess per MCP server (3), so keep modest.
COPILOT_MAX_SESSIONS=50

# ---- Observability (optional) ----
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=devops-copilot

# ---- Agent behavior ----
# Max agent (LLM) calls per investigation turn — bounds the agent<->tools loop.
COPILOT_MAX_ITERATIONS=8
COPILOT_CHECKPOINT_DB=./copilot_checkpoints.sqlite
