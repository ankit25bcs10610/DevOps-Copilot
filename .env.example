# ---- LLM ----
ANTHROPIC_API_KEY=sk-ant-...
# Model used by the agent (Opus for hardest reasoning, Sonnet for cost/speed)
COPILOT_MODEL=claude-sonnet-4-6

# ---- MCP servers ----
# Local repository the filesystem MCP server is allowed to read.
TARGET_REPO_PATH=./sample_repo
# Path the custom logs/metrics MCP server reads demo data from.
LOGS_DATA_PATH=./app/mcp/servers/logs_metrics/sample_data

# GitHub MCP (optional — leave blank to run in demo/offline mode)
GITHUB_TOKEN=

# ---- Observability (optional) ----
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=devops-copilot

# ---- Agent behavior ----
COPILOT_MAX_ITERATIONS=6
COPILOT_CHECKPOINT_DB=./copilot_checkpoints.sqlite
